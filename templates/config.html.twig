{#
 # MailAnalyzer plugin for GLPI — Config form template.
 # GPLv2+
 #}

{% macro select(name, choices, current) %}
   <select name="{{ name }}" class="form-select">
      {% for k, label in choices %}
         <option value="{{ k }}" {% if current == k %}selected{% endif %}>{{ label }}</option>
      {% endfor %}
   </select>
{% endmacro %}

{% import _self as ui %}

<form name="form" action="{{ form_action }}" method="post" data-track-changes="true">
   <input type="hidden" name="id" value="1">
   <input type="hidden" name="config_context" value="plugin:mailanalyzer">
   <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token_value }}">

   <div class="card mb-3">
      <div class="card-header d-flex align-items-center">
         <i class="ti ti-mail me-2"></i>
         <strong>{{ __('Mail Analyzer setup', 'mailanalyzer') }}</strong>
      </div>
      <div class="card-body">
         <div class="alert alert-info d-flex" role="alert">
            <i class="fas fa-info-circle fa-lg me-2 mt-1"></i>
            <div>
               <strong>{{ __('How it works', 'mailanalyzer') }}</strong><br>
               {{ __('This plugin analyzes email headers (Message-ID, References, Thread-Index) to automatically combine related emails into the same ticket, preventing duplicates when CC recipients use "Reply to All".', 'mailanalyzer') }}
            </div>
         </div>

         <h5 class="mt-3"><i class="fas fa-project-diagram me-1"></i> {{ __('Thread tracking', 'mailanalyzer') }}</h5>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Use of Thread index', 'mailanalyzer') }}
               <div class="form-text">{{ __('Enable Microsoft Exchange Thread-Index header support for improved conversation tracking', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8 pt-2">
               {{ ui.select('use_threadindex', yesno_choices, config.use_threadindex) }}
            </div>
         </div>

         <h5 class="mt-4"><i class="fas fa-filter me-1"></i> {{ __('Domain filters', 'mailanalyzer') }}</h5>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">
               <i class="fas fa-check-circle text-success me-1"></i> {{ __('Whitelist Domains', 'mailanalyzer') }}
               <div class="form-text">{{ __('Never block emails from these domains (one per line, e.g., @important.com)', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8">
               <textarea name="whitelist_domains" class="form-control" rows="3">{{ config.whitelist_domains }}</textarea>
            </div>
         </div>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">
               <i class="fas fa-times-circle text-danger me-1"></i> {{ __('Blacklist Domains', 'mailanalyzer') }}
               <div class="form-text">{{ __('Always block emails from these domains (one per line, e.g., @spam.com)', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8">
               <textarea name="blacklist_domains" class="form-control" rows="3">{{ config.blacklist_domains }}</textarea>
            </div>
         </div>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">
               <i class="fas fa-star text-warning me-1"></i> {{ __('VIP senders', 'mailanalyzer') }}
               <div class="form-text">{{ __('VIP senders bypass subject-hash dedup and get max urgency. One entry per line — full address or @domain.', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8">
               <textarea name="vip_senders" class="form-control" rows="3">{{ config.vip_senders }}</textarea>
            </div>
         </div>

         <h5 class="mt-4"><i class="fas fa-brain me-1"></i> {{ __('Smart classification (ITIL)', 'mailanalyzer') }}</h5>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Enable smart classification', 'mailanalyzer') }}
               <div class="form-text">{{ __('Detect Incident vs Service Request from keywords in subject/body', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8 pt-2">
               {{ ui.select('enable_smart_classification', yesno_choices, config.enable_smart_classification) }}
            </div>
         </div>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Incident keywords', 'mailanalyzer') }}
               <div class="form-text">{{ __('One keyword per line; case-insensitive substring match', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8">
               <textarea name="incident_keywords" class="form-control" rows="3">{{ config.incident_keywords }}</textarea>
            </div>
         </div>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Service Request keywords', 'mailanalyzer') }}
               <div class="form-text">{{ __('One keyword per line; case-insensitive substring match', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8">
               <textarea name="request_keywords" class="form-control" rows="3">{{ config.request_keywords }}</textarea>
            </div>
         </div>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('High-urgency keywords', 'mailanalyzer') }}
               <div class="form-text">{{ __('If any of these appear in subject/body, urgency is raised to Very High (5)', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8">
               <textarea name="auto_priority_keywords" class="form-control" rows="2">{{ config.auto_priority_keywords }}</textarea>
            </div>
         </div>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Default ticket type if no keyword matches', 'mailanalyzer') }}</label>
            <div class="col-sm-8">
               {{ ui.select('default_request_type', default_type_choices, config.default_request_type) }}
            </div>
         </div>

         <h5 class="mt-4"><i class="fas fa-shield-alt me-1"></i> {{ __('Smart duplicate detection', 'mailanalyzer') }}</h5>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Enable subject-hash deduplication', 'mailanalyzer') }}
               <div class="form-text">{{ __('Fallback dedup when Message-ID is empty or rotated. SHA1(normalized subject + sender) within a recent time window.', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8 pt-2">
               {{ ui.select('enable_subject_hash_dedup', yesno_choices, config.enable_subject_hash_dedup) }}
            </div>
         </div>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Subject-hash dedup window (minutes)', 'mailanalyzer') }}</label>
            <div class="col-sm-8">
               <input type="number" min="1" max="1440" name="subject_hash_window_minutes" class="form-control" value="{{ config.subject_hash_window_minutes }}">
            </div>
         </div>

         <h5 class="mt-4"><i class="fas fa-user-shield me-1"></i> {{ __('Sender authentication (SPF / DKIM / DMARC)', 'mailanalyzer') }}</h5>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Enable authentication checks', 'mailanalyzer') }}
               <div class="form-text">{{ __('Reads RFC 8601 Authentication-Results header set by the upstream mail server. No DNS lookups are made by the plugin.', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8 pt-2">
               {{ ui.select('enable_auth_validation', yesno_choices, config.enable_auth_validation) }}
            </div>
         </div>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Reject on SPF fail', 'mailanalyzer') }}</label>
            <div class="col-sm-8 pt-2">
               {{ ui.select('reject_on_spf_fail', yesno_choices, config.reject_on_spf_fail) }}
            </div>
         </div>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Reject on DKIM fail', 'mailanalyzer') }}</label>
            <div class="col-sm-8 pt-2">
               {{ ui.select('reject_on_dkim_fail', yesno_choices, config.reject_on_dkim_fail) }}
            </div>
         </div>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Reject on DMARC fail', 'mailanalyzer') }}</label>
            <div class="col-sm-8 pt-2">
               {{ ui.select('reject_on_dmarc_fail', yesno_choices, config.reject_on_dmarc_fail) }}
            </div>
         </div>

         <h5 class="mt-4"><i class="fas fa-clone me-1"></i> {{ __('Attachment deduplication', 'mailanalyzer') }}</h5>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Dedup attachments by SHA-256', 'mailanalyzer') }}
               <div class="form-text">{{ __('Skip duplicate attachments (same SHA-256 content) on the same ticket. Useful for repeated signature/banner images on long threads.', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8 pt-2">
               {{ ui.select('enable_attachment_dedup', yesno_choices, config.enable_attachment_dedup) }}
            </div>
         </div>

         <h5 class="mt-4"><i class="fas fa-bell me-1"></i> {{ __('Alerts', 'mailanalyzer') }}</h5>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Duplicate-storm threshold', 'mailanalyzer') }}
               <div class="form-text">{{ __('Raise a NotificationEvent every N duplicates blocked within the window', 'mailanalyzer') }}</div>
            </label>
            <div class="col-sm-8">
               <input type="number" min="1" max="10000" name="duplicate_alert_threshold" class="form-control" value="{{ config.duplicate_alert_threshold }}">
            </div>
         </div>
         <div class="row mb-3">
            <label class="col-sm-4 col-form-label">{{ __('Duplicate-storm window (seconds)', 'mailanalyzer') }}</label>
            <div class="col-sm-8">
               <input type="number" min="60" max="604800" name="duplicate_alert_window_seconds" class="form-control" value="{{ config.duplicate_alert_window_seconds }}">
            </div>
         </div>

         <div class="d-flex justify-content-center mt-4">
            <button type="submit" name="update" class="btn btn-primary">
               <i class="ti ti-device-floppy me-1"></i> {{ _x('button', 'Save') }}
            </button>
         </div>
      </div>
   </div>
</form>
