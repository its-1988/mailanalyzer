# === Plugin name / setup ===
msgid "Mail Analyzer"
msgstr "Анализатор почты"

msgid "Mail Analyzer setup"
msgstr "Настройка анализатора почты"

msgid "MailAnalyzer"
msgstr "Анализатор почты"

# === Thread tracking ===
msgid "Thread tracking"
msgstr "Отслеживание цепочек"

msgid "Use of Thread index"
msgstr "Использовать Thread-Index"

msgid "Enable Microsoft Exchange Thread-Index header support for improved conversation tracking"
msgstr "Включить поддержку заголовка Thread-Index Microsoft Exchange для улучшенного отслеживания цепочек переписки"

# === Domain filters ===
msgid "Domain filters"
msgstr "Фильтры доменов"

msgid "Whitelist Domains"
msgstr "Белый список доменов"

msgid "Never block emails from these domains (one per line, e.g., @important.com)"
msgstr "Никогда не блокировать письма с этих доменов (по одному в строке, например @important.com)"

msgid "Blacklist Domains"
msgstr "Чёрный список доменов"

msgid "Always block emails from these domains (one per line, e.g., @spam.com)"
msgstr "Всегда блокировать письма с этих доменов (по одному в строке, например @spam.com)"

msgid "VIP senders"
msgstr "VIP-отправители"

msgid "VIP senders bypass subject-hash dedup and get max urgency. One entry per line — full address or @domain."
msgstr "Письма от VIP-отправителей не блокируются дополнительной защитой по хэшу темы и получают максимальную срочность. По одной записи в строке — полный адрес или @домен."

# === Smart classification ===
msgid "Smart classification (ITIL)"
msgstr "Умная классификация (ITIL)"

msgid "Enable smart classification"
msgstr "Включить умную классификацию"

msgid "Detect Incident vs Service Request from keywords in subject/body"
msgstr "Определять тип заявки (Инцидент / Запрос на обслуживание) по ключевым словам в теме/теле"

msgid "Incident keywords"
msgstr "Ключевые слова для инцидентов"

msgid "One keyword per line; case-insensitive substring match"
msgstr "По одному ключевому слову в строке; поиск подстроки без учёта регистра"

msgid "Service Request keywords"
msgstr "Ключевые слова для запросов на обслуживание"

msgid "High-urgency keywords"
msgstr "Ключевые слова повышенной срочности"

msgid "If any of these appear in subject/body, urgency is raised to Very High (5)"
msgstr "При совпадении любого слова в теме/теле срочность поднимается до «Очень высокая» (5)"

msgid "Default ticket type if no keyword matches"
msgstr "Тип заявки по умолчанию (если ни одно правило не сработало)"

msgid "Do not change"
msgstr "Не менять"

msgid "Incident"
msgstr "Инцидент"

msgid "Service Request"
msgstr "Запрос на обслуживание"

# === Smart duplicate detection ===
msgid "Smart duplicate detection"
msgstr "Умное обнаружение дубликатов"

msgid "Enable subject-hash deduplication"
msgstr "Включить дедупликацию по хэшу темы"

msgid "Fallback dedup when Message-ID is empty or rotated. SHA1(normalized subject + sender) within a recent time window."
msgstr "Резервная дедупликация если Message-ID пуст или меняется. SHA1(нормализованная тема + отправитель) в недавнем временном окне."

msgid "Subject-hash dedup window (minutes)"
msgstr "Окно дедупликации по теме (минут)"

# === Alerts ===
msgid "Alerts"
msgstr "Уведомления"

msgid "Duplicate-storm threshold"
msgstr "Порог «шторма дубликатов»"

msgid "Raise a NotificationEvent every N duplicates blocked within the window"
msgstr "Создавать NotificationEvent каждые N заблокированных дубликатов внутри окна"

msgid "Duplicate-storm window (seconds)"
msgstr "Окно «шторма дубликатов» (секунды)"

msgid "High volume of blocked duplicates"
msgstr "Большое количество заблокированных дубликатов"

# === How it works ===
msgid "How it works"
msgstr "Как это работает"

msgid "This plugin analyzes email headers (Message-ID, References, Thread-Index) to automatically combine related emails into the same ticket, preventing duplicates when CC recipients use \"Reply to All\"."
msgstr "Плагин анализирует заголовки писем (Message-ID, References, Thread-Index) и автоматически объединяет связанные письма в одну заявку, предотвращая дубликаты, когда получатели в копии используют «Ответить всем»."

