msgid "Period"
msgstr "Период"

msgid "Last 7 days"
msgstr "Последние 7 дней"

msgid "Last 30 days"
msgstr "Последние 30 дней"

msgid "Last 90 days"
msgstr "Последние 90 дней"

msgid "All time"
msgstr "За всё время"

msgid "Filter Statistics"
msgstr "Фильтр статистики"

msgid "Export CSV"
msgstr "Экспорт в CSV"

# === Activity log ===
msgid "Recent Activity"
msgstr "Недавняя активность"

msgid "Date"
msgstr "Дата"

msgid "Action"
msgstr "Действие"

msgid "Ticket"
msgstr "Заявка"

msgid "Mail Collector"
msgstr "Сборщик почты"

msgid "Message ID"
msgstr "ID сообщения"

msgid "From"
msgstr "От"

msgid "Subject"
msgstr "Тема"

msgid "Reason"
msgstr "Причина"

msgid "Duplicate Blocked"
msgstr "Дубликат заблокирован"

msgid "Followup Created"
msgstr "Создан комментарий"

msgid "Ticket Linked"
msgstr "Создана связанная заявка"

msgid "New Ticket"
msgstr "Новая заявка"

msgid "deleted"
msgstr "удалена"

# === Health check ===
msgid "Mail Collectors Health Check"
msgstr "Состояние сборщиков почты"

msgid "Collector Name"
msgstr "Имя сборщика"

msgid "Active"
msgstr "Активен"

msgid "Connection Status"
msgstr "Статус соединения"

msgid "Last Email Processed (Analyzer)"
msgstr "Последнее обработанное письмо"

msgid "Errors Count"
msgstr "Кол-во ошибок"

msgid "No active mail collectors found."
msgstr "Активные сборщики почты не найдены."

msgid "Failing"
msgstr "Сбой"

msgid "OK"
msgstr "ОК"

msgid "Never"
msgstr "Никогда"

# === Misc ===
msgid "Unsupported mail server type:%s."
msgstr "Неподдерживаемый тип почтового сервера: %s."

msgid "Cleanup orphan entries and old statistics"
msgstr "Очистка осиротевших записей и старой статистики"

msgid "Days to keep statistics (0 = infinite)"
msgstr "Сколько дней хранить статистику (0 — бесконечно)"

# === SPF / DKIM / DMARC ===
msgid "Sender authentication (SPF / DKIM / DMARC)"
msgstr "Аутентификация отправителя (SPF / DKIM / DMARC)"

msgid "Enable authentication checks"
msgstr "Включить проверку аутентификации"

msgid "Reads RFC 8601 Authentication-Results header set by the upstream mail server. No DNS lookups are made by the plugin."
msgstr "Читает заголовок Authentication-Results (RFC 8601), который выставляет вышестоящий почтовый сервер. Плагин не делает запросов в DNS."

msgid "Reject on SPF fail"
msgstr "Отклонять при провале SPF"

msgid "Reject on DKIM fail"
msgstr "Отклонять при провале DKIM"

msgid "Reject on DMARC fail"
msgstr "Отклонять при провале DMARC"

msgid "Auth Failed"
msgstr "Провал аутентификации"

# === Attachment dedup ===
msgid "Attachment deduplication"
msgstr "Дедупликация вложений"

msgid "Dedup attachments by SHA-256"
msgstr "Дедуп вложений по SHA-256"

msgid "Skip duplicate attachments (same SHA-256 content) on the same ticket. Useful for repeated signature/banner images on long threads."
msgstr "Пропускать повторные вложения (одинаковое содержимое по SHA-256) в одной заявке. Полезно при повторяющихся изображениях подписи/баннера в длинных переписках."

msgid "Attachment Deduped"
msgstr "Вложение дедуплицировано"

