msgid_plural "Message-ID records"
msgstr[0] "Запись Message-ID"
msgstr[1] "Записи Message-ID"
msgstr[2] "Записей Message-ID"

msgid "Message-IDs"
msgstr "Message-ID"

msgid "Subject hash"
msgstr "Хэш темы"
